@page
@model RestaurantApp.Pages.Meals.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Meal</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <input type="hidden" asp-for="Meal.MealID" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Meal.Name" class="control-label"></label>
                <input asp-for="Meal.Name" class="form-control" />
                <span asp-validation-for="Meal.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Meal.Price" class="control-label"></label>
                <input asp-for="Meal.Price" class="form-control" />
                <span asp-validation-for="Meal.Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Meal.CategoryID" class="control-label"></label>
                <select asp-for="Meal.CategoryID" class="form-control" asp-items="ViewBag.CategoryID"></select>
                <span asp-validation-for="Meal.CategoryID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Meal.NoteID" class="control-label"></label>
                <select asp-for="Meal.NoteID" class="form-control" asp-items="ViewBag.NoteID">
                    <option value="">-- No Note --</option>
                </select>
                <span asp-validation-for="Meal.NoteID" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}